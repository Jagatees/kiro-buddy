{
  "name": "@jagatees/kiro-buddy",
  "version": "0.1.32",
  "description": "Floating desktop pet overlay for Kiro agent activity",
  "main": "dist/main/main/index.js",
  "bin": {
    "kiro-buddy": "bin/kiro-buddy.cjs"
  },
  "files": [
    "bin",
    "dist/assets",
    "dist/main",
    "dist/renderer",
    "scripts/kiro-status-hook.cjs",
    "scripts/kiro-status-hook.ps1",
    "scripts/install-kiro-hooks.cjs",
    "scripts/install-kiro-cli-hooks.cjs",
    "scripts/verify-windows-ready.cjs",
    "scripts/prepare-electron-app-package.cjs",
    "scripts/kiro-buddy-autostart.cjs",
    "scripts/install-autostart.cjs",
    "scripts/install-macos-autostart.cjs",
    "scripts/install-windows-autostart.cjs",
    "docs",
    "README.md",
    "electron-builder.config.js"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.main.json && node scripts/build-renderer.cjs",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "node scripts/build-renderer.cjs",
    "start": "electron .",
    "status:idle": "node scripts/kiro-status-hook.cjs idle",
    "status:working": "node scripts/kiro-status-hook.cjs working",
    "status:waiting": "node scripts/kiro-status-hook.cjs waiting",
    "status:asking": "node scripts/kiro-status-hook.cjs asking",
    "status:done": "node scripts/kiro-status-hook.cjs done",
    "status:error": "node scripts/kiro-status-hook.cjs error",
    "hooks:install": "node scripts/install-kiro-hooks.cjs",
    "cli-hooks:install": "node scripts/install-kiro-cli-hooks.cjs",
    "windows:verify": "node scripts/verify-windows-ready.cjs",
    "smoke:input-monitor": "node scripts/smoke-input-monitor.cjs",
    "autostart:install": "node scripts/install-autostart.cjs",
    "prepare:electron-app": "node scripts/prepare-electron-app-package.cjs",
    "pack": "npm run prepare:electron-app && electron-builder --dir --config electron-builder.config.js",
    "dist": "npm run prepare:electron-app && electron-builder --config electron-builder.config.js",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:property": "jest tests/property",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "electron": "^39.8.5",
    "electron-store": "^8.2.0",
    "lottie-web": "^5.12.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.0.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.21.5",
    "eslint": "^9.3.0",
    "fast-check": "^3.19.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.46.4"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests",
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^@shared/(.*)$": "<rootDir>/src/shared/$1",
      "^@main/(.*)$": "<rootDir>/src/main/$1",
      "^@renderer/(.*)$": "<rootDir>/src/renderer/$1"
    }
  }
}
